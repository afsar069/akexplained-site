<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }} | AK Explained</title>
<meta name="description" content="{{ description }}">
<link rel="icon" href="/assets/logo.png" type="image/png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Literata:ital,wght@0,400;0,600;0,700;1,400&family=Source+Sans+3:wght@400;500;600;700&display=swap">
<link rel="stylesheet" href="/assets/site.css">
</head>
<body>
<a class="skip" href="#main">Skip to content</a>

<header class="site-header">
  <div class="bar">
    <a class="brand" href="/">
      <img src="/assets/logo.png" alt="AK Explained logo" width="40" height="40">
      <span>AK <i>Explained</i></span>
    </a>
 <nav class="primary-nav" aria-label="Primary">
      <span class="navitem">
        <a href="/exams/">Exams &#9662;</a>
        <span class="dd">
          <a href="/exams/net/">UGC NET / JRF / SET English</a>
          <a href="/exams/pgt/">PGT English Literature</a>
          <a href="/exams/tgt/">TGT English Literature</a>
          <a href="/university/ccs-meerut/">CCS University English</a>
          <a href="/university/ignou/">IGNOU English Literature</a>
          <a href="/university/du/">Delhi University</a>
        </span>
      </span>
      <span class="navitem">
        <a href="/quizzes/">Quizzes &#9662;</a>
        <span class="dd">
          <a href="/quizzes/pyq/">PYQ</a>
          <a href="/quizzes/mcq/">MCQ</a>
        </span>
      </span>
      <span class="navitem">
        <a href="/publish-with-us/">Your Creativity</a>
      </span>
      <span class="navitem">
        <a href="/guides/">Guide</a>
      </span>
      <span class="navitem">
        <a href="/about/">About</a>
      </span>
      <span class="navitem">
        <a href="/help/">Help &#9662;</a>
        <span class="dd">
          <a href="/contact/">Contact us</a>
        </span>
      </span>
    </nav>
  </div>
</header>

<div class="wrap"><p class="crumb"><a href="/">Home</a><span>/</span>{% if crumbs %}{% for c in crumbs %}<a href="{{ c.href }}">{{ c.label }}</a><span>/</span>{% endfor %}{% endif %}{{ crumb_label or title }}</p></div>

<main id="main">

{% if pagehead != false %}
<section class="pagehead">
  <span class="mark" aria-hidden="true">{{ mark or title | first | upper }}</span>
  <div class="wrap">
    <p class="eyebrow">{{ eyebrow or title }}</p>
    <h1>{{ title }}</h1>
    {% if description %}<p class="lede">{{ description }}</p>{% endif %}
  </div>
</section>
{% endif %}

<div class="wrap">
<div class="article">
{{ content | safe }}
</div>
</div>

</main>

<footer class="site-footer">
  <div class="wrap">
    <p class="id"><img src="/assets/logo.png" alt="" width="34" height="34"><span><b>AK Explained</b> — All about English Literature</span></p>
    <nav aria-label="Footer">
      <a href="/">Home</a>
      <a href="/exams/">Exams</a>
      <a href="/notes/">Notes</a>
      <a href="/guides/">Guides</a>
      <a href="/quizzes/">Quizzes</a>
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
    </nav>
    <p class="legal">
      <span>&copy; 2026 AK Explained &middot; Prof. Afsar Khan</span>
      <a href="/privacy/">Privacy Policy</a>
      <a href="/terms/">Terms</a>
    </p>
  </div>
</footer>

